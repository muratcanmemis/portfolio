  <script>
    (() => {
      const projects=[
        {id:'low-tide',title:'Low Tide',category:'Documentary',year:'2024',duration:'03:42',role:'Narrative Editor',client:'Northlight Studio',resolution:'4K UHD',color:'#2e86d8',visual:'linear-gradient(135deg,#2e86d8,#182b52)',summary:'A quiet coastal portrait shaped around the rhythms of a fishing town and the people who keep returning to it.',description:'Low Tide began as a collection of observational scenes. The final edit gives those fragments a deliberate pulse: weather, work and memory overlap without forcing the story into a conventional arc. This long-form field is ready for a full case study.',tech:['Premiere Pro','DaVinci Resolve','Pro Tools'],credits:[['Director','Mara Chen'],['Cinematography','J. Flores'],['Sound Mix','N. Sutton']],video:{kind:'mp4',src:'media/low-tide-teaser.mp4'}},
        {id:'undertow',title:'Halcyon — Undertow',category:'Music Video',year:'2024',duration:'02:15',role:'Editor & Colorist',client:'Halcyon Records',resolution:'4K DCI',color:'#9a5cf0',visual:'linear-gradient(135deg,#9a5cf0,#301a52)',summary:'A saturated performance film cut to shift between intimate detail and kinetic release.',description:'Movement becomes the transition language, allowing each chorus to gather momentum before returning to a close human scale. A modular grade preserved skin tone while practical lights bloom.',tech:['Premiere Pro','After Effects','DaVinci Resolve'],credits:[['Artist','Halcyon'],['Director','Iris Vale'],['Producer','Modern Reel Co.']],video:{kind:'mp4',src:'media/undertow-teaser.mp4'}},
        {id:'fieldnote',title:'Fieldnote — Autumn',category:'Commercial',year:'2023',duration:'01:04',role:'Full Post Production',client:'Fieldnote Films',resolution:'4K UHD',color:'#22c4ce',visual:'linear-gradient(135deg,#22c4ce,#0f3538)',summary:'A seasonal product story with a tactile visual language and a polished editorial finish.',description:'From first assembly through conform and delivery, the workflow kept product detail crisp while allowing the film room to breathe. The final campaign was versioned for social, retail and broadcast.',tech:['Premiere Pro','After Effects','Frame.io'],credits:[['Creative Director','Jules Young'],['DP','R. Kareem'],['Agency','Fieldnote']],video:{kind:'mp4',src:'media/fieldnote-autumn.mp4'}},
        {id:'slow-coast',title:'Slow Coast',category:'Short Film',year:'2023',duration:'05:30',role:'Editor & Sound Designer',client:'Slow Coast Media',resolution:'2K DCI',color:'#e1793a',visual:'linear-gradient(135deg,#e1793a,#4a2812)',summary:'A five-minute fictional study of distance, weather and the things left unsaid.',description:'The film was built around an elastic sense of time. Sound design carries the transitions and lets the environment become a second narrator. The result is intimate, spare and designed for a cinema-grade finish.',tech:['Premiere Pro','Pro Tools','Resolve'],credits:[['Writer / Director','T. Bell'],['Composer','L. Imani'],['Mix','Alex Rivera']],video:{kind:'mp4',src:'media/slow-coast.mp4'}},
        {id:'aperture',title:'Aperture — Launch Teaser',category:'Social Cut',year:'2022',duration:'00:48',role:'Motion Designer',client:'Aperture Collective',resolution:'3840 × 2160',color:'#2e86d8',visual:'linear-gradient(135deg,#2e86d8,#183a2e)',summary:'A compact launch asset designed to make a new visual identity feel alive in under a minute.',description:'Typography, sound hits and modular transitions were designed as an adaptable system rather than a one-off edit. The campaign could move cleanly between vertical and horizontal delivery formats.',tech:['After Effects','Premiere Pro','Illustrator'],credits:[['Brand Design','Aperture'],['Motion Design','Alex Rivera'],['Music','Motel Audio']],video:{kind:'mp4',src:'media/aperture-launch.mp4'}},
        {id:'origins',title:'Frameworks — Origins',category:'Documentary',year:'2021',duration:'04:12',role:'Assistant Editor',client:'Frameworks',resolution:'4K UHD',color:'#9a5cf0',visual:'linear-gradient(135deg,#9a5cf0,#1c2350)',summary:'An origin story for a studio whose work begins with curiosity and craft.',description:'As assistant editor, I developed the organization system, prepared string-outs and helped shape the interview-driven narrative. The process reinforced how much a thoughtful post workflow can protect creative momentum.',tech:['Premiere Pro','Avid Media Composer','Frame.io'],credits:[['Director','Sam Rios'],['Editor','D. Whitman'],['Assistant Editor','Alex Rivera']],video:{kind:'mp4',src:'media/frameworks-origins.mp4'}}
      ];
      const services=[
        {name:'Filmmaking',detail:'Production from first concept to final delivery.',icon:'<svg class="service-icon" viewBox="0 0 24 24" aria-hidden="true"><path d="M3 9h18v12H3zM3 9l3-5h4l3 5m1 0 3-5h3l-3 5M7 14h10M8 18h8"/></svg>',color:'#e1793a'}, {name:'Documentary Filmmaking',detail:'Research, field craft and authored post.',icon:'<svg class="service-icon" viewBox="0 0 24 24" aria-hidden="true"><rect x="3" y="6" width="14" height="12" rx="2"/><path d="m17 10 4-2v8l-4-2z"/></svg>',color:'#2e86d8'}, {name:'Commercial Production',detail:'Campaign films built for attention.',icon:'<svg class="service-icon" viewBox="0 0 24 24" aria-hidden="true"><path d="M3 10v4h4l8 4V6L7 10zm4 4 1.5 4H12l-1.5-3.3M18 9a4 4 0 0 1 0 6"/></svg>',color:'#9a5cf0'}, {name:'Cinematography',detail:'Intentional light, lens and movement.',icon:'<svg class="service-icon" viewBox="0 0 24 24" aria-hidden="true"><rect x="3" y="7" width="14" height="11" rx="2"/><circle cx="10" cy="12.5" r="3"/><path d="m17 10 4-2v9l-4-2zM7 7l1-2h4l1 2"/></svg>',color:'#22c4ce'}, {name:'Editing',detail:'Structure, rhythm and emotional pace.',icon:'<svg class="service-icon" viewBox="0 0 24 24" aria-hidden="true"><circle cx="6" cy="7" r="2.5"/><circle cx="6" cy="17" r="2.5"/><path d="m8 8.5 10 7M8 15.5l10-7"/></svg>',color:'#e1793a'}, {name:'Color Grading',detail:'A finish with a point of view.',icon:'<svg class="service-icon" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 3a9 9 0 1 0 0 18c2.5 0 3.5-1.3 3.5-2.4 0-1.3-1-2.1-2.2-2.1h-1.1a1.6 1.6 0 0 1 0-3.2H15a3.5 3.5 0 0 0 0-7z"/><circle cx="7.5" cy="11" r=".7"/><circle cx="10" cy="7.5" r=".7"/></svg>',color:'#9a5cf0'}, {name:'Motion Graphics',detail:'Titles and systems that move with purpose.',icon:'<svg class="service-icon" viewBox="0 0 24 24" aria-hidden="true"><path d="m12 3 1.5 5.5L19 10l-5.5 1.5L12 17l-1.5-5.5L5 10l5.5-1.5zM19 15l.7 2.3L22 18l-2.3.7L19 21l-.7-2.3L16 18l2.3-.7z"/></svg>',color:'#2e86d8'}, {name:'Creative Direction',detail:'A visual through-line from brief to delivery.',icon:'<svg class="service-icon" viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="12" r="8"/><path d="m15.5 8.5-2.2 4.8-4.8 2.2 2.2-4.8zM12 4v2M20 12h-2M12 20v-2M4 12h2"/></svg>',color:'#22c4ce'}
      ];
      const clients=[
        {name:'Drama Yapım',logo:'DY',quote:'Selected film and production collaboration.',category:'Production',year:'2025',color:'#2e86d8'},
        {name:'ISF Studios',logo:'ISF',quote:'Selected studio and production collaboration.',category:'Studio',year:'2025',color:'#e1793a'},
        {name:'Sectore6',logo:'S6',quote:'Selected creative production collaboration.',category:'Creative Production',year:'2025',color:'#9a5cf0'},
        {name:'Yeşil Yapım',logo:'YY',quote:'Selected film production collaboration.',category:'Production',year:'2024',color:'#22c4ce'},
        {name:'Mesai Film',logo:'MF',quote:'Selected commercial and film collaboration.',category:'Film',year:'2024',color:'#e1793a'},
        {name:'Patik Production',logo:'PP',quote:'Selected production collaboration.',category:'Production',year:'2024',color:'#2e86d8'},
        {name:'Creative Production',logo:'CP',quote:'Selected creative collaboration.',category:'Creative',year:'2023',color:'#9a5cf0'},
        {name:'Hacıyatmaz Film',logo:'HF',quote:'Selected film and post-production collaboration.',category:'Film',year:'2023',color:'#22c4ce'}
      ];
      const $=selector=>document.querySelector(selector); const $$=selector=>[...document.querySelectorAll(selector)];
      const escapeHTML=value=>String(value).replace(/[&<>'"]/g,char=>({'&':'&amp;','<':'&lt;','>':'&gt;',"'":'&#39;','"':'&quot;'}[char]));
      $('#project-browser').innerHTML=projects.map(project=>`<button class="project-card" type="button" data-project="${project.id}" style="--accent:${project.color};--visual:${project.visual}"><div class="project-thumb"><span class="tag">${escapeHTML(project.category)}</span><span class="duration">${project.duration}</span><span class="resolution">${project.resolution}</span><span class="play-icon">▶</span></div><div class="project-meta"><span class="project-cat">${escapeHTML(project.category)}</span><h3>${escapeHTML(project.title)}</h3><p>${project.year} · ${escapeHTML(project.role)}</p><footer><span>${escapeHTML(project.client)}</span><span>OPEN CLIP ↗</span></footer></div></button>`).join('');
      $('#clients-grid').innerHTML=clients.map(client=>`<article class="client-card" style="--accent:${client.color}"><span class="client-logo" aria-label="${escapeHTML(client.name)} logo">${client.logo}</span><h3>${escapeHTML(client.name)}</h3><p>${escapeHTML(client.quote)}</p><div class="client-details"><span>${escapeHTML(client.category)}</span><span>${client.year}</span></div></article>`).join('');
      const serviceMarkup=service=>`<article class="service-card" style="--accent:${service.color}"><span class="service-symbol">${service.icon}</span><h3>${escapeHTML(service.name)}</h3><p>${escapeHTML(service.detail)}</p></article>`;
      $('#services-grid').innerHTML=services.map(serviceMarkup).join('');
      $('#source-services').innerHTML=services.map((service,index)=>`<button type="button" class="service-source-card" data-service="${index}" style="--accent:${service.color}" aria-pressed="false"><b>${service.icon} &nbsp;${escapeHTML(service.name)}</b><span>${escapeHTML(service.detail)}</span></button>`).join('');
      $$('.service-source-card').forEach(card=>card.addEventListener('click',()=>{$$('.service-source-card').forEach(item=>{item.classList.remove('active');item.setAttribute('aria-pressed','false')});card.classList.add('active');card.setAttribute('aria-pressed','true')}));

      function source(name){$$('.source-slide').forEach(slide=>slide.classList.toggle('active',slide.dataset.slide===name));$$('.source-tab[data-source]').forEach(tab=>tab.classList.toggle('active',tab.dataset.source===name));$('#source-title').textContent=name==='services'?'Services':'About Me'}
      $$('[data-source]').forEach(button=>button.addEventListener('click',()=>{source(button.dataset.source);if(button.classList.contains('timeline-clip')) $('#workspace').scrollIntoView({behavior:'smooth',block:'start'});$$('.timeline-clip').forEach(clip=>clip.classList.toggle('active',clip===button))}));
      $$('[data-scroll]').forEach(button=>button.addEventListener('click',()=>{const target=$('#'+button.dataset.scroll);target?.scrollIntoView({behavior:'smooth',block:button.dataset.scroll==='workspace'?'start':'center'});if(button.classList.contains('timeline-clip')){$$('.timeline-clip').forEach(clip=>clip.classList.toggle('active',clip===button))}}));
      let seconds=0;setInterval(()=>{seconds++;const h=String(Math.floor(seconds/3600)).padStart(2,'0');const m=String(Math.floor((seconds%3600)/60)).padStart(2,'0');const s=String(seconds%60).padStart(2,'0');$('#clock').textContent=`${h}:${m}:${s}`},1000);
      const showreelEmbed=$('#showreel-embed');

      const modal=$('#project-modal'),modalVideo=$('#modal-video'),modalEmbed=$('#modal-embed'),modalPoster=$('#modal-poster'),modalLoader=$('#modal-loader'),modalProgress=$('#modal-progress');let currentProject=null,lastTrigger=null;
      const formatTime=time=>{if(!Number.isFinite(time))return'00:00:00';const h=Math.floor(time/3600),m=Math.floor(time%3600/60),s=Math.floor(time%60);return[h,m,s].map(n=>String(n).padStart(2,'0')).join(':')};
      function embedURL(url){if(url.includes('youtu.be/'))return`https://www.youtube.com/embed/${url.split('youtu.be/')[1].split(/[?&]/)[0]}`;if(url.includes('youtube.com/watch')){const id=new URL(url).searchParams.get('v');return id?`https://www.youtube.com/embed/${id}`:url}if(url.includes('vimeo.com/')&&!url.includes('player.vimeo.com'))return`https://player.vimeo.com/video/${url.split('vimeo.com/')[1].split(/[?&#]/)[0]}`;return url}
      function setPlayer(project){currentProject=project;$('.video-frame').style.setProperty('--visual',project.visual);modalPoster.textContent=project.video.kind==='mp4'?'LOCAL MP4 · READY TO REPLACE':'EMBEDDED TEASER';modalPoster.hidden=false;modalLoader.hidden=false;modalVideo.pause();modalVideo.removeAttribute('src');modalVideo.hidden=true;modalEmbed.removeAttribute('src');modalEmbed.hidden=true;modalProgress.value=0;$('#modal-time').textContent=`00:00:00 / ${project.duration}`;if(project.video.kind==='mp4'){modalVideo.src=project.video.src;modalVideo.load()}else{modalEmbed.src=embedURL(project.video.src);modalEmbed.hidden=false;modalPoster.hidden=true;modalLoader.hidden=true}}
      function openProject(project,trigger){lastTrigger=trigger;$$('.project-card').forEach(card=>card.classList.toggle('selected',card===trigger));$('#modal-clip').textContent=`${project.id.replace(/-/g,'_').toUpperCase()}.SRC`;$('#modal-kicker').textContent=`${project.category} · ${project.year} · ${project.duration}`;$('#modal-kicker').style.setProperty('--accent',project.color);$('#modal-title').textContent=project.title;$('#modal-summary').textContent=project.summary;$('#modal-description').textContent=project.description;$('#modal-metadata').innerHTML=[['Category',project.category],['Year',project.year],['Duration',project.duration],['Production role',project.role],['Client',project.client],['Format',project.resolution]].map(([key,value])=>`<div class="metadata-row"><span>${key}</span><b>${escapeHTML(value)}</b></div>`).join('');$('#modal-tech').innerHTML=project.tech.map(item=>`<span>${escapeHTML(item)}</span>`).join('');$('#modal-credits').innerHTML=project.credits.map(([role,name])=>`<div><b>${escapeHTML(role)}:</b> ${escapeHTML(name)}</div>`).join('');setPlayer(project);modal.showModal()}
      function closeProject(){modalVideo.pause();modalEmbed.removeAttribute('src');modal.close();lastTrigger?.focus()}
      $('#project-browser').addEventListener('click',event=>{const card=event.target.closest('.project-card');if(!card)return;const project=projects.find(item=>item.id===card.dataset.project);if(project)openProject(project,card)});$$('[data-close]').forEach(button=>button.addEventListener('click',closeProject));modal.addEventListener('click',event=>{if(event.target===modal)closeProject()});modal.addEventListener('cancel',event=>{event.preventDefault();closeProject()});
      modalVideo.addEventListener('loadeddata',()=>{modalVideo.hidden=false;modalPoster.hidden=true;modalLoader.hidden=true});modalVideo.addEventListener('waiting',()=>modalLoader.hidden=false);modalVideo.addEventListener('playing',()=>{modalLoader.hidden=true;$('#modal-play').textContent='Ⅱ'});modalVideo.addEventListener('pause',()=>$('#modal-play').textContent='▶');modalVideo.addEventListener('error',()=>{modalVideo.hidden=true;modalLoader.hidden=true;modalPoster.hidden=false;modalPoster.textContent='ADD YOUR LOCAL MP4 OR EMBED URL'});modalVideo.addEventListener('timeupdate',()=>{const duration=modalVideo.duration||0;modalProgress.value=duration?modalVideo.currentTime/duration*100:0;$('#modal-time').textContent=`${formatTime(modalVideo.currentTime)} / ${formatTime(duration)}`});
      $('#modal-play').addEventListener('click',()=>{if(currentProject?.video.kind==='mp4')modalVideo.paused?modalVideo.play().catch(()=>{}):modalVideo.pause()});$('#modal-mute').addEventListener('click',()=>modalVideo.muted=!modalVideo.muted);$('#modal-volume').addEventListener('input',event=>{modalVideo.volume=event.target.value;modalVideo.muted=false});modalProgress.addEventListener('input',event=>{if(modalVideo.duration)modalVideo.currentTime=modalVideo.duration*event.target.value/100});$('#modal-fullscreen').addEventListener('click',()=>$('#modal-video-frame').requestFullscreen?.());
      document.addEventListener('keydown',event=>{if(!modal.open)return;if(event.key==='Escape')closeProject();if(event.key===' '&&!/INPUT|TEXTAREA/.test(document.activeElement.tagName)){event.preventDefault();$('#modal-play').click()}});
      $$('[data-autoresize]').forEach(field=>field.addEventListener('input',()=>{field.style.height='auto';field.style.height=`${Math.max(76,field.scrollHeight)}px`}));
      $('#contact-form').addEventListener('submit',event=>{event.preventDefault();const form=new FormData(event.currentTarget);const subject=encodeURIComponent(`Portfolio contact from ${form.get('name')}`);const body=encodeURIComponent(`Name: ${form.get('name')}\nYour E-Mail: ${form.get('email')}\n\nMessage:\n${form.get('message')}`);$('#contact-status').textContent='Opening your e-mail app…';window.location.href=`mailto:muratcanmemis@live.com?subject=${subject}&body=${body}`;});
    })();
